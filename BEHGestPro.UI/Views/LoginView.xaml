<Window x:Class="BEHGestPro.UI.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:BEHGestPro.UI.Converters"
        Title="BEHGest Pro — Connexion"
        Height="560" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <conv:InvertBoolConverter x:Key="InvertBool" />

        <!-- TextBox arrondi avec texte visible -->
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="#2C3250" />
            <Setter Property="Foreground"               Value="White" />
            <Setter Property="CaretBrush"               Value="White" />
            <Setter Property="SelectionBrush"           Value="#00ACC1" />
            <Setter Property="BorderBrush"              Value="#3A4168" />
            <Setter Property="BorderThickness"          Value="1.5" />
            <Setter Property="FontSize"                 Value="14" />
            <Setter Property="Height"                   Value="46" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding"                  Value="12,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="PART_Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                TextBlock.Foreground="{TemplateBinding Foreground}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="#00ACC1" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="#5C6BC0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PasswordBox arrondi avec texte visible -->
        <Style x:Key="RoundedPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background"               Value="#2C3250" />
            <Setter Property="Foreground"               Value="White" />
            <Setter Property="BorderBrush"              Value="#3A4168" />
            <Setter Property="BorderThickness"          Value="1.5" />
            <Setter Property="FontSize"                 Value="14" />
            <Setter Property="Height"                   Value="46" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding"                  Value="12,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="PART_Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                TextBlock.Foreground="{TemplateBinding Foreground}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="#00ACC1" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="#5C6BC0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1128" Offset="0" />
                <GradientStop Color="#1A1F38" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <!-- Drag zone -->
            <Border Height="40" VerticalAlignment="Top" Background="Transparent"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown" />

            <!-- Close button -->
            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,8,12,0" Width="28" Height="28"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand" Click="CloseBtn_Click">
                <TextBlock Text="✕" FontSize="13" Foreground="#78909C" />
            </Button>

            <StackPanel VerticalAlignment="Center" Margin="44,0">

                <!-- Logo -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,36">
                    <Border Width="72" Height="72" CornerRadius="36"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1565C0" Offset="0" />
                                <GradientStop Color="#00ACC1" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="B" FontSize="36" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="BEHGest Pro" FontSize="26" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" />
                    <TextBlock Text="Système de gestion intégrée" FontSize="12"
                               Foreground="#78909C" HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- Email -->
                <TextBlock Text="Adresse email" FontSize="11" FontWeight="SemiBold"
                           Foreground="#B0BEC5" Margin="0,0,0,6" />
                <TextBox x:Name="TxtEmail"
                         Style="{StaticResource RoundedTextBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Password -->
                <TextBlock Text="Mot de passe" FontSize="11" FontWeight="SemiBold"
                           Foreground="#B0BEC5" Margin="0,16,0,6" />
                <PasswordBox x:Name="TxtPassword"
                             Style="{StaticResource RoundedPasswordBox}" />

                <!-- Error message -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#EF9A9A" FontSize="12"
                           Margin="0,10,0,0" TextWrapping="Wrap"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />

                <!-- Login Button -->
                <Button x:Name="BtnLogin"
                        Margin="0,20,0,0" Height="48"
                        Cursor="Hand"
                        Click="BtnLogin_Click"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBool}}">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1565C0" Offset="0" />
                            <GradientStop Color="#00ACC1" Offset="1" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Login" VerticalAlignment="Center"
                                                Margin="0,0,8,0" Foreground="White" />
                        <TextBlock Text="Se connecter" VerticalAlignment="Center"
                                   FontSize="15" FontWeight="SemiBold" Foreground="White" />
                    </StackPanel>
                </Button>

                <!-- Loading indicator -->
                <TextBlock Text="Connexion en cours..." FontSize="12"
                           Foreground="#00ACC1" HorizontalAlignment="Center"
                           Margin="0,8,0,0"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                <TextBlock Text="v1.0.0 — BEHGest Pro" FontSize="10" Foreground="#455A64"
                           HorizontalAlignment="Center" Margin="0,20,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
