<UserControl x:Class="BEHGestPro.UI.Views.Paiements.PaiementFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:BEHGestPro.UI.Converters"
             Width="560" Background="{StaticResource SurfaceMediumBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InvertBoolConverter x:Key="InvertBool" />

        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#90A4AE" />
            <Setter Property="Margin"     Value="0,10,0,4" />
        </Style>
        <Style x:Key="FBox" TargetType="TextBox">
            <Setter Property="Background"               Value="#1A1F3A" />
            <Setter Property="Foreground"               Value="White" />
            <Setter Property="CaretBrush"               Value="White" />
            <Setter Property="SelectionBrush"           Value="#00ACC1" />
            <Setter Property="BorderBrush"              Value="#3A4168" />
            <Setter Property="BorderThickness"          Value="1" />
            <Setter Property="Padding"                  Value="10,7" />
            <Setter Property="FontSize"                 Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">

        <!-- Sélection commande (liaison automatique) -->
        <Border Background="#0D1128" CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="🔗  Lier à une commande (optionnel)" Foreground="#00ACC1"
                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ComboBox ItemsSource="{Binding Commandes}"
                          SelectedItem="{Binding SelectedCommande}"
                          Background="#1A1F3A" Foreground="White" BorderBrush="#3A4168" Padding="10,7">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Numero}" FontWeight="SemiBold" Foreground="White" Margin="0,0,8,0" />
                                <TextBlock Text=" — " Foreground="#546E7A" />
                                <TextBlock Text="{Binding ClientNom}" Foreground="#90A4AE" Margin="4,0,8,0" />
                                <TextBlock Text="{Binding CoutTotal, StringFormat=N0}" Foreground="#00ACC1" />
                                <TextBlock Text=" XAF" Foreground="#546E7A" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="↑ La sélection remplit automatiquement les montants et la source."
                           Foreground="#546E7A" FontSize="10" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- Référence -->
        <TextBlock Text="Référence" Style="{StaticResource Lbl}" />
        <TextBox Text="{Binding Paiement.Reference}" IsReadOnly="True"
                 Style="{StaticResource FBox}" Background="#131829" Foreground="#546E7A" />

        <!-- Type Source / Mode -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition /><ColumnDefinition Width="10" /><ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Type Source" Style="{StaticResource Lbl}" />
                <ComboBox ItemsSource="{Binding TypesSources}"
                          SelectedItem="{Binding Paiement.TypeSource}"
                          Background="#1A1F3A" Foreground="White" BorderBrush="#3A4168" Padding="10,7" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Mode de Paiement" Style="{StaticResource Lbl}" />
                <ComboBox ItemsSource="{Binding ModesPaiement}"
                          SelectedItem="{Binding Paiement.ModePaiement}"
                          Background="#1A1F3A" Foreground="White" BorderBrush="#3A4168" Padding="10,7" />
            </StackPanel>
        </Grid>

        <!-- Montants -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition /><ColumnDefinition Width="10" /><ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Montant Total (XAF) *" Style="{StaticResource Lbl}" />
                <TextBox Text="{Binding Paiement.MontantTotal, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FBox}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Montant Versé (XAF)" Style="{StaticResource Lbl}" />
                <TextBox Text="{Binding Paiement.MontantVerse, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FBox}" />
            </StackPanel>
        </Grid>

        <!-- Récapitulatif restant -->
        <Border Background="#131829" CornerRadius="6" Padding="10,8" Margin="0,4,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Restant à payer : " Foreground="#90A4AE" FontSize="12" />
                <TextBlock Text="{Binding Paiement.MontantRestant, StringFormat=N0}"
                           Foreground="#EF9A9A" FontWeight="Bold" FontSize="13" />
                <TextBlock Text=" XAF" Foreground="#546E7A" FontSize="12" />
            </StackPanel>
        </Border>

        <!-- Notes -->
        <TextBlock Text="Notes / Observations" Style="{StaticResource Lbl}" />
        <TextBox Text="{Binding Paiement.Notes, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource FBox}" Height="50" TextWrapping="Wrap" VerticalContentAlignment="Top" />

        <!-- Erreur -->
        <Border Background="#1A3040" CornerRadius="6" Padding="10,8" Margin="0,12,0,0"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF9A9A"
                       FontSize="12" TextWrapping="Wrap" />
        </Border>

        <!-- Boutons -->
        <Grid Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition /><ColumnDefinition Width="10" /><ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Annuler"
                    Style="{StaticResource BtnOutline}"
                    Click="CancelBtn_Click"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBool}}" />
            <Button Grid.Column="2" Style="{StaticResource BtnGradient}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBool}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Text="Enregistrer" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
