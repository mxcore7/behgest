<UserControl x:Class="BEHGestPro.UI.Views.Apprenants.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:BEHGestPro.UI.ViewModels"
             xmlns:conv="clr-namespace:BEHGestPro.UI.Converters"
             Background="{StaticResource SurfaceDarkBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:MontantConverter x:Key="MontantConv" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Loading overlay -->
        <Border Grid.RowSpan="2" Background="#80000000" Panel.ZIndex="10"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Loading" Width="48" Height="48" Foreground="#00ACC1">
                    <materialDesign:PackIcon.RenderTransform>
                        <RotateTransform x:Name="LoadingRotate" CenterX="24" CenterY="24" />
                    </materialDesign:PackIcon.RenderTransform>
                </materialDesign:PackIcon>
                <TextBlock Text="Chargement..." Foreground="White" Margin="0,12,0,0"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="0" Grid.RowSpan="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- KPI Cards -->
                <UniformGrid Columns="3" Rows="2" HorizontalAlignment="Stretch">

                    <!-- Apprenants -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,12,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1565C0" Offset="0" />
                                <GradientStop Color="#1976D2" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="{Binding TotalApprenants}" FontSize="36" FontWeight="Bold"
                                           Foreground="White" />
                                <TextBlock Text="Apprenants" Foreground="#90CAF9" FontSize="13" />
                            </StackPanel>
                            <materialDesign:PackIcon Kind="AccountGroup" Width="44" Height="44"
                                                    Foreground="#FFFFFF30" HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom" />
                        </Grid>
                    </Border>

                    <!-- Formations actives -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,12,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00838F" Offset="0" />
                                <GradientStop Color="#00ACC1" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="{Binding FormationsActives}" FontSize="36" FontWeight="Bold"
                                           Foreground="White" />
                                <TextBlock Text="Sessions actives" Foreground="#80DEEA" FontSize="13" />
                            </StackPanel>
                            <materialDesign:PackIcon Kind="BookOpenVariant" Width="44" Height="44"
                                                    Foreground="#FFFFFF30" HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom" />
                        </Grid>
                    </Border>

                    <!-- Commandes -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,0,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6A1B9A" Offset="0" />
                                <GradientStop Color="#8E24AA" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="{Binding CommandesEnCours}" FontSize="36" FontWeight="Bold"
                                           Foreground="White" />
                                <TextBlock Text="Commandes en cours" Foreground="#CE93D8" FontSize="13" />
                            </StackPanel>
                            <materialDesign:PackIcon Kind="ClipboardList" Width="44" Height="44"
                                                    Foreground="#FFFFFF30" HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom" />
                        </Grid>
                    </Border>

                    <!-- Paiements du mois -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,12,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1B5E20" Offset="0" />
                                <GradientStop Color="#2E7D32" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="{Binding PaiementsMois, Converter={StaticResource MontantConv}}"
                                           FontSize="22" FontWeight="Bold" Foreground="White" />
                                <TextBlock Text="Paiements du mois" Foreground="#A5D6A7" FontSize="13" />
                            </StackPanel>
                            <materialDesign:PackIcon Kind="CreditCard" Width="44" Height="44"
                                                    Foreground="#FFFFFF30" HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom" />
                        </Grid>
                    </Border>

                    <!-- Stagiaires -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,12,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E65100" Offset="0" />
                                <GradientStop Color="#F57F17" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="{Binding StagiairesActuels}" FontSize="36" FontWeight="Bold"
                                           Foreground="White" />
                                <TextBlock Text="Stagiaires actuels" Foreground="#FFE0B2" FontSize="13" />
                            </StackPanel>
                            <materialDesign:PackIcon Kind="AccountSchool" Width="44" Height="44"
                                                    Foreground="#FFFFFF30" HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom" />
                        </Grid>
                    </Border>

                    <!-- Salaires en attente -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,0,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#B71C1C" Offset="0" />
                                <GradientStop Color="#C62828" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="{Binding SalairesEnAttente}" FontSize="36" FontWeight="Bold"
                                           Foreground="White" />
                                <TextBlock Text="Salaires en attente" Foreground="#FFCDD2" FontSize="13" />
                            </StackPanel>
                            <materialDesign:PackIcon Kind="CurrencyUsd" Width="44" Height="44"
                                                    Foreground="#FFFFFF30" HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom" />
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- Inscriptions chart placeholder -->
                <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Inscriptions — 12 derniers mois" Style="{StaticResource H2}"
                                   FontSize="14" Margin="0,0,0,16" />
                        <ItemsControl ItemsSource="{Binding InscriptionsMensuelles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="6,0" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                        <TextBlock Text="{Binding NbInscriptions}" FontSize="10"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center" />
                                        <Border Width="28" CornerRadius="4,4,0,0" Margin="0,2,0,0"
                                                Height="{Binding NbInscriptions, Converter={x:Static conv:HeightMultiplierConverter.Instance}}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#1565C0" Offset="0" />
                                                    <GradientStop Color="#00ACC1" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="{Binding Mois}" FontSize="9"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   HorizontalAlignment="Center" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
