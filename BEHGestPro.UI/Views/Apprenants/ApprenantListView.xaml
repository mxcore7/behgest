<UserControl x:Class="BEHGestPro.UI.Views.Apprenants.ApprenantListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:BEHGestPro.UI.Converters"
             Background="{StaticResource SurfaceDarkBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StatutToLibelleConverter x:Key="StatutLib" />
        <conv:StatutToColorConverter x:Key="StatutColor" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Action Bar -->
        <Border Grid.Row="0" Style="{StaticResource ActionBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Grid Grid.Column="0" MaxWidth="380">
                    <TextBox x:Name="TxtSearch"
                             Style="{StaticResource SearchBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="36,6,10,6"
                             materialDesign:HintAssist.Hint="Rechercher un apprenant..."
                             materialDesign:HintAssist.Foreground="#78909C" />
                    <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18"
                                            Foreground="#78909C" Margin="10,0,0,0"
                                            VerticalAlignment="Center" HorizontalAlignment="Left" />
                </Grid>

                <Button Grid.Column="1" Style="{StaticResource BtnOutline}" Margin="8,0,0,0"
                        Command="{Binding ResetFiltersCommand}" Content="Réinitialiser" />

                <Button Grid.Column="2" Style="{StaticResource BtnGradient}" Margin="8,0,0,0"
                        Command="{Binding CreateCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountPlus" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Nouvel apprenant" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Apprenants}"
                      SelectedItem="{Binding SelectedApprenant}"
                      Style="{StaticResource ModernDataGrid}"
                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource DataGridRowStyle}"
                      CellStyle="{StaticResource DataGridCellStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Matricule" Binding="{Binding Matricule}" Width="130" />
                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="140" />
                    <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="140" />
                    <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="120" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                    <DataGridTemplateColumn Header="Actions" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="6,0">
                                    <Button Style="{StaticResource BtnIcon}" ToolTip="Éditer" Margin="2,0"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16" Foreground="#00ACC1" />
                                    </Button>
                                    <Button Style="{StaticResource BtnIcon}" ToolTip="Supprimer" Margin="2,0"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" Foreground="#EF5350" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
