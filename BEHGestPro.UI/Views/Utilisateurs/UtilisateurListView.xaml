<UserControl x:Class="BEHGestPro.UI.Views.Utilisateurs.UtilisateurListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:BEHGestPro.UI.Converters"
             Background="{StaticResource SurfaceDarkBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Action bar -->
        <Border Grid.Row="0" Style="{StaticResource ActionBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Gestion des comptes utilisateurs"
                           Foreground="#90A4AE" FontSize="13" VerticalAlignment="Center" />
                <Button Grid.Column="1" Style="{StaticResource BtnGradient}" Margin="8,0,0,0"
                        Command="{Binding CreateCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountPlus" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Nouveau compte" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Utilisateurs}"
                      Style="{StaticResource ModernDataGrid}"
                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource DataGridRowStyle}"
                      CellStyle="{StaticResource DataGridCellStyle}"
                      AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="120" />
                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="120" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200" />
                    <DataGridTextColumn Header="Rôle" Binding="{Binding Role}" Width="130" />
                    <DataGridCheckBoxColumn Header="Actif" Binding="{Binding Actif}" Width="60" />
                    <DataGridTemplateColumn Header="Actions" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,0">
                                    <Button Style="{StaticResource BtnIcon}" ToolTip="Modifier" Margin="2,0"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16" Foreground="#00ACC1" />
                                    </Button>
                                    <Button Style="{StaticResource BtnIcon}" ToolTip="Activer / Désactiver" Margin="2,0"
                                            Command="{Binding DataContext.ToggleActifCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="AccountOff" Width="16" Height="16" Foreground="#FFA726" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
