<UserControl x:Class="BEHGestPro.UI.Views.Employes.EmployeFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:BEHGestPro.UI.Converters"
             Width="540" Background="{StaticResource SurfaceMediumBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InvertBoolConverter x:Key="InvertBool" />

        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#90A4AE" />
            <Setter Property="Margin"     Value="0,10,0,4" />
        </Style>
        <Style x:Key="FBox" TargetType="TextBox">
            <Setter Property="Background"               Value="#1A1F3A" />
            <Setter Property="Foreground"               Value="White" />
            <Setter Property="CaretBrush"               Value="White" />
            <Setter Property="SelectionBrush"           Value="#00ACC1" />
            <Setter Property="BorderBrush"              Value="#3A4168" />
            <Setter Property="BorderThickness"          Value="1" />
            <Setter Property="Padding"                  Value="10,7" />
            <Setter Property="FontSize"                 Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">

        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Photo -->
            <StackPanel Grid.Column="0">
                <Border Width="80" Height="80" CornerRadius="40" Background="#131829" 
                        BorderBrush="#3A4168" BorderThickness="1" ClipToBounds="True">
                    <Grid>
                        <materialDesign:PackIcon Kind="Account" Width="40" Height="40" Foreground="#3A4168"
                                                HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Image Source="{Binding Employe.PhotoPath}" Stretch="UniformToFill" />
                    </Grid>
                </Border>
                <Button Style="{StaticResource BtnOutline}" Height="28" Margin="0,8,0,0" Padding="8,0"
                        Command="{Binding SelectPhotoCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Camera" Width="14" Height="14" Margin="0,0,4,0" />
                        <TextBlock Text="Photo" FontSize="11" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Matricule -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock Text="Matricule Employé" Style="{StaticResource Lbl}" />
                <TextBox Text="{Binding Employe.Matricule}" IsReadOnly="True"
                         Style="{StaticResource FBox}" Background="#131829" Foreground="#546E7A" />
            </StackPanel>
        </Grid>

        <!-- Nom / Prénom -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition /><ColumnDefinition Width="10" /><ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Nom *" Style="{StaticResource Lbl}" />
                <TextBox Text="{Binding Employe.Nom, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FBox}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Prénom *" Style="{StaticResource Lbl}" />
                <TextBox Text="{Binding Employe.Prenom, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FBox}" />
            </StackPanel>
        </Grid>

        <!-- Poste / Département -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition /><ColumnDefinition Width="10" /><ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Poste" Style="{StaticResource Lbl}" />
                <TextBox Text="{Binding Employe.Poste, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FBox}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Département" Style="{StaticResource Lbl}" />
                <TextBox Text="{Binding Employe.Departement, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FBox}" />
            </StackPanel>
        </Grid>

        <!-- Tél / Email -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition /><ColumnDefinition Width="10" /><ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Téléphone" Style="{StaticResource Lbl}" />
                <TextBox Text="{Binding Employe.Telephone, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FBox}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Email" Style="{StaticResource Lbl}" />
                <TextBox Text="{Binding Employe.Email, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FBox}" />
            </StackPanel>
        </Grid>

        <!-- Salaire Base / Actif -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition /><ColumnDefinition Width="10" /><ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Salaire de Base (XAF)" Style="{StaticResource Lbl}" />
                <TextBox Text="{Binding Employe.SalaireBase, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FBox}" />
            </StackPanel>
            <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,10">
                <CheckBox Content="Employé Actif" IsChecked="{Binding Employe.Actif}"
                          Foreground="White" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>

        <!-- Erreur -->
        <Border Background="#1A3040" CornerRadius="6" Padding="10,8" Margin="0,12,0,0"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF9A9A"
                       FontSize="12" TextWrapping="Wrap" />
        </Border>

        <!-- Boutons -->
        <Grid Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition /><ColumnDefinition Width="10" /><ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Annuler"
                    Style="{StaticResource BtnOutline}"
                    Click="CancelBtn_Click"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBool}}" />
            <Button Grid.Column="2" Style="{StaticResource BtnGradient}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBool}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Text="Enregistrer" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
