<UserControl x:Class="BEHGestPro.UI.Views.Salaires.SalaireListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:BEHGestPro.UI.Converters"
             Background="{StaticResource SurfaceDarkBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StatutToLibelleConverter x:Key="StatutLib" />
        <conv:StatutToColorConverter x:Key="StatutColor" />
        <conv:MontantConverter x:Key="MontantConv" />
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource ActionBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" MaxWidth="380">
                    <TextBox Style="{StaticResource SearchBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="36,6,10,6" />
                    <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18"
                                            Foreground="#78909C" Margin="10,0,0,0"
                                            VerticalAlignment="Center" HorizontalAlignment="Left" />
                </Grid>
                <Button Grid.Column="1" Style="{StaticResource BtnGradient}" Margin="8,0,0,0"
                        Command="{Binding CreateCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CurrencyUsd" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Nouveau salaire" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Salaires}"
                      Style="{StaticResource ModernDataGrid}"
                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource DataGridRowStyle}"
                      CellStyle="{StaticResource DataGridCellStyle}"
                      AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Employé" Binding="{Binding Employe.NomComplet}" Width="160" />
                    <DataGridTextColumn Header="Période" Binding="{Binding PeriodeLibelle}" Width="120" />
                    <DataGridTextColumn Header="Base (XAF)" Binding="{Binding SalaireBase, StringFormat=N0}" Width="110" />
                    <DataGridTextColumn Header="Primes" Binding="{Binding PrimeTotal, StringFormat=N0}" Width="100" />
                    <DataGridTextColumn Header="Retenues" Binding="{Binding Retenues, StringFormat=N0}" Width="100" />
                    <DataGridTextColumn Header="Avance Déduite" Binding="{Binding AvanceDeduite, StringFormat=N0}" Width="120" />
                    <DataGridTextColumn Header="Net à Payer" Binding="{Binding NetAPayer, StringFormat=N0}" Width="120" />
                    <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="*" />
                    <DataGridTemplateColumn Header="Actions" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,0">
                                    <Button Style="{StaticResource BtnIcon}" ToolTip="Valider Paiement" Margin="2,0"
                                            Command="{Binding DataContext.ValiderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="CheckCircle" Width="16" Height="16" Foreground="#2E7D32" />
                                    </Button>
                                    <Button Style="{StaticResource BtnIcon}" ToolTip="Imprimer Fiche" Margin="2,0"
                                            Command="{Binding DataContext.PrintFicheCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Printer" Width="16" Height="16" Foreground="#1565C0" />
                                    </Button>
                                    <Button Style="{StaticResource BtnIcon}" ToolTip="Supprimer" Margin="2,0"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" Foreground="#EF5350" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>

