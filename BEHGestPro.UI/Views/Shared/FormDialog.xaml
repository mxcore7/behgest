<Window x:Class="BEHGestPro.UI.Views.Shared.FormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource SurfaceMediumBrush}"
        BorderBrush="{StaticResource SurfaceLightBrush}"
        BorderThickness="1"
        MinWidth="540" MinHeight="200">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <!-- Drag handle -->
    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="WindowStyle" Value="None" />
        </Style>
    </Window.Style>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource SideNavGradient}"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid Margin="20,0">
                <TextBlock x:Name="TxtTitle"
                           Text="Formulaire"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center" />
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CloseBtn_Click">
                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18"
                                            Foreground="#78909C" />
                </Button>
            </Grid>
        </Border>

        <!-- Content host -->
        <ContentControl x:Name="ContentHost"
                        Grid.Row="1"
                        Margin="0" />
    </Grid>
</Window>
