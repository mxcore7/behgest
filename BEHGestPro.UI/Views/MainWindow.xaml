<Window x:Class="BEHGestPro.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:BEHGestPro.UI.ViewModels"
        xmlns:vma="clr-namespace:BEHGestPro.UI.ViewModels.Apprenants"
        xmlns:vms="clr-namespace:BEHGestPro.UI.ViewModels.Stagiaires"
        xmlns:vmf="clr-namespace:BEHGestPro.UI.ViewModels.Formations"
        xmlns:vmp="clr-namespace:BEHGestPro.UI.ViewModels.Paiements"
        xmlns:vmc="clr-namespace:BEHGestPro.UI.ViewModels.Commandes"
        xmlns:vmsal="clr-namespace:BEHGestPro.UI.ViewModels.Salaires"
        xmlns:vme="clr-namespace:BEHGestPro.UI.ViewModels.Employes"
        xmlns:views="clr-namespace:BEHGestPro.UI.Views.Apprenants"
        xmlns:viewss="clr-namespace:BEHGestPro.UI.Views.Stagiaires"
        xmlns:viewsf="clr-namespace:BEHGestPro.UI.Views.Formations"
        xmlns:viewsp="clr-namespace:BEHGestPro.UI.Views.Paiements"
        xmlns:viewsc="clr-namespace:BEHGestPro.UI.Views.Commandes"
        xmlns:viewssal="clr-namespace:BEHGestPro.UI.Views.Salaires"
        xmlns:viewse="clr-namespace:BEHGestPro.UI.Views.Employes"
        xmlns:conv="clr-namespace:BEHGestPro.UI.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="BEHGest Pro"
        Width="1100" Height="650"
        MinWidth="1100" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceDarkBrush}">

    <Window.Resources>
        <!-- DataTemplates to map ViewModels to Views -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vma:ApprenantListViewModel}">
            <views:ApprenantListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:StagiaireListViewModel}">
            <viewss:StagiaireListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmf:FormationListViewModel}">
            <viewsf:FormationListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmp:PaiementListViewModel}">
            <viewsp:PaiementListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmc:CommandeListViewModel}">
            <viewsc:CommandeListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmsal:SalaireListViewModel}">
            <viewssal:SalaireListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vme:EmployeListViewModel}">
            <viewse:EmployeListView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDE NAV ═══ -->
        <Border Grid.Column="0" Background="{StaticResource SideNavGradient}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Border Grid.Row="0" Padding="20,24,20,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="38" Height="38" CornerRadius="10" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1565C0" Offset="0"/>
                                        <GradientStop Color="#00ACC1" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="B" FontSize="22" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="BEHGest" FontSize="15" FontWeight="Bold" Foreground="White" />
                                <TextBlock Text="Pro" FontSize="11" Foreground="#00ACC1" FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                        <Separator Background="#2A3050" Margin="0,16,0,0" />
                    </StackPanel>
                </Border>

                <!-- Nav Items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel Margin="10,8">
                        <!-- Dashboard -->
                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"
                                Style="{StaticResource BtnIcon}" Width="Auto" Height="Auto"
                                Margin="0,2" HorizontalAlignment="Stretch">
                            <Border Style="{StaticResource NavItem}" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20"
                                                            Foreground="#00ACC1" VerticalAlignment="Center" />
                                    <TextBlock Text="Tableau de bord" Margin="12,0,0,0"
                                               Foreground="White" FontSize="13" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Button>

                        <TextBlock Text="GESTION" FontSize="10" FontWeight="Bold" Foreground="#455A64"
                                   Margin="12,12,0,6" />

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Apprenants"
                                Style="{StaticResource BtnIcon}" Width="Auto" Height="Auto"
                                Margin="0,2" HorizontalAlignment="Stretch">
                            <Border Style="{StaticResource NavItem}" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountGroup" Width="20" Height="20"
                                                            Foreground="#B0BEC5" VerticalAlignment="Center"/>
                                    <TextBlock Text="Apprenants" Margin="12,0,0,0"
                                               Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Stagiaires"
                                Style="{StaticResource BtnIcon}" Width="Auto" Height="Auto"
                                Margin="0,2" HorizontalAlignment="Stretch">
                            <Border Style="{StaticResource NavItem}" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountSchool" Width="20" Height="20"
                                                            Foreground="#B0BEC5" VerticalAlignment="Center"/>
                                    <TextBlock Text="Stagiaires" Margin="12,0,0,0"
                                               Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Formations"
                                Style="{StaticResource BtnIcon}" Width="Auto" Height="Auto"
                                Margin="0,2" HorizontalAlignment="Stretch">
                            <Border Style="{StaticResource NavItem}" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="BookOpenVariant" Width="20" Height="20"
                                                            Foreground="#B0BEC5" VerticalAlignment="Center"/>
                                    <TextBlock Text="Formations" Margin="12,0,0,0"
                                               Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <TextBlock Text="FINANCES" FontSize="10" FontWeight="Bold" Foreground="#455A64"
                                   Margin="12,12,0,6" />

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Paiements"
                                Style="{StaticResource BtnIcon}" Width="Auto" Height="Auto"
                                Margin="0,2" HorizontalAlignment="Stretch">
                            <Border Style="{StaticResource NavItem}" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CreditCard" Width="20" Height="20"
                                                            Foreground="#B0BEC5" VerticalAlignment="Center"/>
                                    <TextBlock Text="Paiements" Margin="12,0,0,0"
                                               Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Commandes"
                                Style="{StaticResource BtnIcon}" Width="Auto" Height="Auto"
                                Margin="0,2" HorizontalAlignment="Stretch">
                            <Border Style="{StaticResource NavItem}" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ClipboardList" Width="20" Height="20"
                                                            Foreground="#B0BEC5" VerticalAlignment="Center"/>
                                    <TextBlock Text="Commandes" Margin="12,0,0,0"
                                               Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <TextBlock Text="RH" FontSize="10" FontWeight="Bold" Foreground="#455A64"
                                   Margin="12,12,0,6" />

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Employes"
                                Style="{StaticResource BtnIcon}" Width="Auto" Height="Auto"
                                Margin="0,2" HorizontalAlignment="Stretch">
                            <Border Style="{StaticResource NavItem}" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="BadgeAccount" Width="20" Height="20"
                                                            Foreground="#B0BEC5" VerticalAlignment="Center"/>
                                    <TextBlock Text="Employés" Margin="12,0,0,0"
                                               Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Salaires"
                                Style="{StaticResource BtnIcon}" Width="Auto" Height="Auto"
                                Margin="0,2" HorizontalAlignment="Stretch">
                            <Border Style="{StaticResource NavItem}" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CurrencyUsd" Width="20" Height="20"
                                                            Foreground="#B0BEC5" VerticalAlignment="Center"/>
                                    <TextBlock Text="Salaires" Margin="12,0,0,0"
                                               Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- User + Logout -->
                <Border Grid.Row="2" Padding="14,12" BorderBrush="#2A3050" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUserName}" Foreground="White"
                                       FontSize="12" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="Utilisateur connecté" Foreground="#455A64" FontSize="10" />
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource BtnIcon}"
                                Command="{Binding LogoutCommand}" ToolTip="Déconnexion">
                            <materialDesign:PackIcon Kind="Logout" Width="18" Height="18" Foreground="#EF9A9A" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ CONTENT AREA ═══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceMediumBrush}"
                    BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <TextBlock Text="{Binding ActiveModule}" FontSize="18" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center" />
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='ddd dd MMM yyyy', ConverterCulture='fr-FR'}"
                                   Foreground="#78909C" FontSize="12" Margin="0,0,16,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Module content -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}" Margin="0" />
        </Grid>
    </Grid>
</Window>
