<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Couleurs primaires -->
    <Color x:Key="PrimaryColor">#1565C0</Color>
    <Color x:Key="PrimaryLightColor">#1976D2</Color>
    <Color x:Key="PrimaryDarkColor">#0D47A1</Color>
    <Color x:Key="AccentColor">#00ACC1</Color>
    <Color x:Key="AccentLightColor">#00BCD4</Color>

    <!-- Surfaces -->
    <Color x:Key="SurfaceDark">#1E2130</Color>
    <Color x:Key="SurfaceMedium">#252A3D</Color>
    <Color x:Key="SurfaceLight">#2C3250</Color>
    <Color x:Key="SurfaceCard">#2A2F45</Color>

    <!-- Sémantique -->
    <Color x:Key="SuccessColor">#2E7D32</Color>
    <Color x:Key="WarningColor">#F57F17</Color>
    <Color x:Key="DangerColor">#C62828</Color>
    <Color x:Key="InfoColor">#0277BD</Color>

    <!-- Texte -->
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#B0BEC5</Color>
    <Color x:Key="TextMuted">#78909C</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDark}" />
    <SolidColorBrush x:Key="SurfaceMediumBrush" Color="{StaticResource SurfaceMedium}" />
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource SurfaceLight}" />
    <SolidColorBrush x:Key="SurfaceCardBrush" Color="{StaticResource SurfaceCard}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />

    <!-- Gradients -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1565C0" Offset="0" />
        <GradientStop Color="#00ACC1" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SideNavGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0D1128" Offset="0" />
        <GradientStop Color="#1A1F38" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
