<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- TextBlock styles -->
    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="Subtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="Caption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>

    <!-- Card style (Border) -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceCardBrush}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="3" Opacity="0.3" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- StatCard style -->
    <Style x:Key="StatCard" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="Padding" Value="20" />
        <Setter Property="MinWidth" Value="160" />
    </Style>

    <!-- ActionBar -->
    <Style x:Key="ActionBar" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceMediumBrush}" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <!-- SearchBox -->
    <Style x:Key="SearchBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryLightBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Height" Value="36" />
    </Style>

    <!-- NavItem highlight -->
    <Style x:Key="NavItem" TargetType="Border">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Margin" Value="4,2" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="{StaticResource PrimaryColor}" Opacity="0.25" />
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="NavItemActive" TargetType="Border" BasedOn="{StaticResource NavItem}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1565C0" Offset="0" />
                    <GradientStop Color="#00ACC1" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Input Label style -->
    <Style x:Key="InputLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,3" />
    </Style>

    <!-- Section separator -->
    <Style x:Key="Separator" TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}" />
        <Setter Property="Margin" Value="0,8" />
    </Style>

    <!-- StatusBadge base -->
    <Style x:Key="StatusBadge" TargetType="Border">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,3" />
    </Style>

    <!-- ComboBoxItem global style -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="Black" />
        <Setter Property="Background" Value="White" />
    </Style>

</ResourceDictionary>
